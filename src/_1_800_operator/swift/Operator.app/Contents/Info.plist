<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleExecutable</key>
    <string>Operator</string>
    <key>CFBundleIdentifier</key>
    <string>com.1-800-operator.audio-capture</string>
    <key>CFBundleIconFile</key>
    <string>Operator</string>
    <key>CFBundleName</key>
    <string>Operator</string>
    <key>CFBundleDisplayName</key>
    <string>Operator</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.4</string>
    <key>LSUIElement</key>
    <true/>
    <key>NSAudioCaptureUsageDescription</key>
    <string>Operator transcribes meeting audio so it can join chat conversations.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>Operator transcribes your voice locally for dial-mode chat.</string>
    <!-- Opts into AVCaptureDeviceTypeContinuityCamera (the new type) for
         Continuity Camera discovery, silencing the AVFoundation deprecation
         warning that fires during AVCaptureDevice enumeration. We don't
         actually use Continuity Cameras (we're audio-only), but the
         enumeration path that finds the default audio device internally
         touches the same device-type registry, so opting in cleanly here
         keeps stderr quiet and removes the deprecation time-bomb. -->
    <key>NSCameraUseContinuityCameraDeviceType</key>
    <true/>
</dict>
</plist>
